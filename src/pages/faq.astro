---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import PrizeFaq from '../components/PrizeFaq.astro';
---

<Layout title="FAQ - Braize" description="Braize questions and prize rules.">
  <main class="page help-page">
    <TopNav active="faq" />

    <section class="window help-shell">
      <div class="title-bar" style="--title-color: var(--hc-purple); --title-color-2: var(--hc-red);">
        <div class="title-bar-text">FAQ.exe</div>
      </div>
      <div class="help-body">
        <header class="help-hero">
          <p class="eyebrow">RULES + FAQ</p>
          <h1>What counts?</h1>
          <p>Short version: make browser-adjacent stuff, keep proof, submit something people can open.</p>
        </header>
        <PrizeFaq />
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .help-page { padding-top: 24px; }
  .help-shell { margin-top: 14px; }
  .help-body {
    padding: 18px;
    background: linear-gradient(135deg, rgba(166, 51, 214, 0.18), rgba(236, 55, 80, 0.14)), var(--win-face);
  }
  .help-hero {
    position: relative;
    padding: 18px;
    background: #050505;
    color: #fff;
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.25);
    margin-bottom: 18px;
  }
  .help-hero::after {
    content: 'if confused: ask, do not overthink';
    position: absolute;
    right: 14px;
    bottom: -12px;
    max-width: 190px;
    padding: 7px 10px;
    font-family: var(--font-hand);
    font-size: 1.08rem;
    line-height: 1;
    color: #111;
    background: #e6ffd8;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.15);
    transform: rotate(-2deg);
  }
  .help-hero h1 {
    margin: 0;
    font-size: clamp(2.8rem, 9vw, 5.2rem);
    color: #fff;
    text-shadow: 3px 3px 0 var(--hc-purple), 6px 6px 0 rgba(236, 55, 80, 0.45);
  }
</style>
