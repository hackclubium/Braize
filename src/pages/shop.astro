---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import { shopItems } from '../data/shopItems';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Shop - Braize" description="Braize prize tiers.">
  <main class="page shop-page">
    <TopNav active="shop" />

    <section class="window shop-shell">
      <div class="title-bar" style="--title-color: var(--hc-yellow); --title-color-2: var(--hc-orange);">
        <div class="title-bar-text">Shop.exe</div>
      </div>
      <div class="shop-body">
        <header class="shop-hero">
          <p class="eyebrow">PRIZE TIERS</p>
          <h1>Prizes</h1>
          <p>No checkout. No points. Ship a project, get reviewed, then eligible rewards show up.</p>
        </header>

        <div class="shop-grid">
          {shopItems.map((item) => (
            <article class="shop-card">
              <div class="shop-tag">{item.tag}</div>
              <img src={item.image.src} alt="" class="shop-image" loading="lazy" />
              <h2>{item.name}</h2>
              <p>{item.desc}</p>
              <div class="shop-cost">{item.cost}</div>
              <a href={`${base}/shop/${item.slug}/`} class="btn-mini">More info</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .shop-page {
    padding-top: 24px;
  }

  .shop-shell {
    margin-top: 14px;
  }

  .shop-body {
    padding: 18px;
    background: linear-gradient(135deg, rgba(241, 196, 15, 0.22), rgba(255, 140, 55, 0.16)), var(--win-face);
  }

  .shop-hero {
    padding: 18px;
    background: #050505;
    color: #fff;
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.25);
  }

  .shop-hero h1 {
    margin: 0;
    font-size: clamp(2.8rem, 9vw, 5.2rem);
    color: #fff;
    text-shadow: 3px 3px 0 var(--hc-orange), 6px 6px 0 rgba(241, 196, 15, 0.45);
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 18px;
    padding: 16px;
    background: #111;
    box-shadow: inset 0 0 0 4px #333, inset 0 0 0 8px #050505, 8px 8px 0 rgba(0,0,0,0.28);
  }

  .shop-card {
    position: relative;
    display: grid;
    gap: 10px;
    padding: 16px;
    min-height: 250px;
    background:
      radial-gradient(circle at 24px 20px, var(--hc-red) 0 5px, transparent 6px),
      linear-gradient(180deg, #fff, #ffe9a8);
    box-shadow: inset -1px -1px var(--win-shadow), inset 1px 1px var(--win-light-highlight), 8px 8px 0 rgba(0, 0, 0, 0.2);
    transform: rotate(-0.45deg);
  }

  .shop-card:nth-child(2n) { transform: rotate(0.45deg); background-color: #e9fbff; }

  .shop-card:hover {
    transform: translateY(-4px) rotate(-0.5deg);
  }

  .shop-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 5px;
    background: linear-gradient(90deg, var(--hc-red), var(--hc-orange), var(--hc-yellow), var(--hc-green), var(--hc-cyan), var(--hc-purple));
  }

  .shop-tag,
  .shop-cost {
    width: max-content;
    padding: 3px 8px;
    font-family: var(--font-display);
    background: #000;
    color: var(--hc-yellow);
  }

  .shop-card h2 {
    margin: 10px 0 0;
  }

  .shop-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border: 3px solid #050505;
    background: #fff;
  }

  .shop-card p {
    margin: 0;
  }

  .shop-card .btn-mini {
    align-self: end;
    width: max-content;
  }
</style>
