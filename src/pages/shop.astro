---
import Layout from '../layouts/Layout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const items = [
  {
    name: 'Browser Sticker Pack',
    cost: '1 ship',
    tag: 'starter',
    desc: 'A tiny pile of browser-themed vinyl stickers for laptops, notebooks, and questionable hardware.',
  },
  {
    name: 'Braize Mouse',
    cost: 'solid ship',
    tag: 'gear',
    desc: 'Wireless mouse reward for projects that run, feel complete, and survive review clicks.',
  },
  {
    name: 'Domain + Hosting',
    cost: 'standout ship',
    tag: 'web',
    desc: 'A public home for the thing you built: domain credit plus hosting for a year.',
  },
  {
    name: 'Portable Monitor',
    cost: 'exceptional ship',
    tag: 'boss tier',
    desc: 'Extra screen space for from-scratch browsers, ambitious engines, or projects with serious polish.',
  },
];
---

<Layout title="Shop - Braize" description="Browse Braize reward placeholders.">
  <main class="page shop-page">
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href={base || '/'}>Braize</a>
      <span class="sep">›</span>
      <span>Shop</span>
    </nav>

    <section class="window shop-shell">
      <div class="title-bar" style="--title-color: var(--hc-yellow); --title-color-2: var(--hc-orange);">
        <div class="title-bar-text">Shop.exe</div>
      </div>
      <div class="shop-body">
        <header class="shop-hero">
          <p class="eyebrow">REWARD CATALOG</p>
          <h1>Prize Shop</h1>
          <p>Placeholder rewards while review rules settle. Nothing buys with money; projects earn rewards by shipping.</p>
        </header>

        <div class="shop-grid">
          {items.map((item) => (
            <article class="shop-card">
              <div class="shop-tag">{item.tag}</div>
              <h2>{item.name}</h2>
              <p>{item.desc}</p>
              <div class="shop-cost">{item.cost}</div>
              <button type="button" class="btn-mini" disabled>Not Claimable Yet</button>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .shop-page {
    padding-top: 24px;
  }

  .shop-shell {
    margin-top: 14px;
  }

  .shop-body {
    padding: 18px;
    background: linear-gradient(135deg, rgba(241, 196, 15, 0.22), rgba(255, 140, 55, 0.16)), var(--win-face);
  }

  .shop-hero {
    padding: 18px;
    background: #050505;
    color: #fff;
    box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.25);
  }

  .shop-hero h1 {
    margin: 0;
    font-size: clamp(2.8rem, 9vw, 5.2rem);
    color: #fff;
    text-shadow: 3px 3px 0 var(--hc-orange), 6px 6px 0 rgba(241, 196, 15, 0.45);
  }

  .shop-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 18px;
    padding: 16px;
    background: #111;
    box-shadow: inset 0 0 0 4px #333, inset 0 0 0 8px #050505, 8px 8px 0 rgba(0,0,0,0.28);
  }

  .shop-card {
    position: relative;
    display: grid;
    gap: 10px;
    padding: 16px;
    min-height: 250px;
    background:
      radial-gradient(circle at 50% 18%, rgba(255,255,255,0.9), transparent 22%),
      linear-gradient(180deg, #fff, #ffe9a8);
    box-shadow: inset -1px -1px var(--win-shadow), inset 1px 1px var(--win-light-highlight), 8px 8px 0 rgba(0, 0, 0, 0.2);
  }

  .shop-card:hover {
    transform: translateY(-4px) rotate(-0.5deg);
  }

  .shop-card::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    height: 5px;
    background: linear-gradient(90deg, var(--hc-red), var(--hc-orange), var(--hc-yellow), var(--hc-green), var(--hc-cyan), var(--hc-purple));
  }

  .shop-tag,
  .shop-cost {
    width: max-content;
    padding: 3px 8px;
    font-family: var(--font-display);
    background: #000;
    color: var(--hc-yellow);
  }

  .shop-card h2 {
    margin: 10px 0 0;
  }

  .shop-card p {
    margin: 0;
  }

  .shop-card button {
    align-self: end;
    opacity: 0.7;
    cursor: not-allowed;
  }
</style>
