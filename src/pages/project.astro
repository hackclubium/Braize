---
import Layout from '../layouts/Layout.astro';
import Panel from '../components/Panel.astro';
import TopNav from '../components/TopNav.astro';
---

<Layout title="Project Pages Under Construction - Braize" description="Braize project pages are under construction.">
  <main class="page">
    <TopNav active="explore" crumb="Project" />

    <Panel id="project" title="Project Pages Under Construction" icon="folder" color="var(--hc-purple)" color2="var(--hc-blue)">
      <p class="construction-note">
        Public project pages are paused while submissions move to Fillout and Airtable.
      </p>
      <p>Explore stays up. New submitted projects will come back here once the new flow is ready.</p>
      <a class="btn btn-accent" href="/Braize/explore/">Back to Explore</a>
    </Panel>
  </main>
</Layout>

<style is:global>
  .construction-note {
    max-width: 58ch;
    padding: 14px 16px;
    background: #fff4a8;
    box-shadow: 5px 5px 0 rgba(0,0,0,0.14);
    transform: rotate(-0.5deg);
  }
</style>
