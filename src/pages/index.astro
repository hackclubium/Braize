---
import Layout from '../layouts/Layout.astro';
import BrowserWindow from '../components/BrowserWindow.astro';
import Panel from '../components/Panel.astro';
import WhatCounts from '../components/WhatCounts.astro';
import Timeline from '../components/Timeline.astro';
import Footer from '../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout
  title="Braize - a Hack Club YSWS"
  description="Make something browser-adjacent for Braize, a Hack Club YSWS."
>
  <main class="page">
    <BrowserWindow />

    <Panel id="about" title="About Braize" icon="info" color="var(--hc-blue)" color2="var(--hc-cyan)">
      <div class="about-note-stack">
        <p>
          Braize is a Hack Club YSWS. Make
          something browser-ish, keep a little trail of what happened, and submit
          it through the submission form.
        </p>
        <p>
          Scope can be tiny or huge. A practical extension counts. A cursed tab
          toy counts. A from-scratch browser counts if you are brave.
        </p>
      </div>
    </Panel>

    <Panel id="what-counts" title="What Counts" icon="check" color="var(--hc-green)" color2="var(--hc-cyan)">
      <WhatCounts />
    </Panel>

    <Panel id="how-it-works" title="How It Works" icon="gear" color="var(--hc-orange)" color2="var(--hc-yellow)">
      <Timeline />
    </Panel>

    <Panel id="prize" title="Prize + FAQ" icon="gift" color="var(--hc-purple)" color2="var(--hc-red)">
      <p class="hand-note">Prizes are intentionally simple: submit working browser stuff, get reviewed, maybe get browser credits, gear, or a monitor.</p>
      <p>Full tier breakdown and common questions live on the FAQ page.</p>
      <a class="btn btn-accent" href={`${base}/faq/`}>Full Prize + FAQ</a>
      <a class="btn" href={`${base}/guides/`}>Read guides</a>
    </Panel>

    <Footer />
  </main>
</Layout>

<style is:global>
  .about-note-stack {
    display: grid;
    gap: 12px;
  }

  .about-note-stack p,
  .hand-note {
    max-width: 62ch;
    padding: 14px 16px;
    background: #fffbe0;
    box-shadow: 5px 5px 0 rgba(0,0,0,0.14);
    transform: rotate(-0.6deg);
  }

  .about-note-stack p:nth-child(2) {
    background: #e9fbff;
    transform: rotate(0.5deg);
  }

</style>
