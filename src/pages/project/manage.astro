---
import Layout from '../../layouts/Layout.astro';
import Panel from '../../components/Panel.astro';
import TopNav from '../../components/TopNav.astro';
---

<Layout title="Project Manager Under Construction - Braize" description="Braize project management is under construction.">
  <main class="page">
    <TopNav active="dashboard" crumb="Manage Project" />

    <Panel id="manage" title="Project Manager Under Construction" icon="folder" color="var(--hc-blue)" color2="var(--hc-purple)">
      <p class="construction-note">
        Project management is being replaced by a Fillout submission form backed by Airtable.
      </p>
      <p>No action needed here yet. Keep building, save proof, and submit once the new form lands.</p>
      <a class="btn btn-accent" href="/Braize/dashboard/">Submission status</a>
    </Panel>
  </main>
</Layout>

<style is:global>
  .construction-note {
    max-width: 58ch;
    padding: 14px 16px;
    background: #fff4a8;
    box-shadow: 5px 5px 0 rgba(0,0,0,0.14);
    transform: rotate(-0.5deg);
  }
</style>
