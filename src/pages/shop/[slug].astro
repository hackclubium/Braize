---
import Layout from '../../layouts/Layout.astro';
import TopNav from '../../components/TopNav.astro';
import { shopItems } from '../../data/shopItems';

export function getStaticPaths() {
  return shopItems.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title={`${item.name} - Braize Shop`} description={item.desc}>
  <main class="page shop-page">
    <TopNav active="shop" crumb={item.name} />

    <section class="window shop-shell">
      <div class="title-bar" style="--title-color: var(--hc-yellow); --title-color-2: var(--hc-orange);">
        <div class="title-bar-text">{item.name}.txt</div>
      </div>
      <div class="shop-body item-detail">
        <a href={`${base}/shop/`} class="btn-mini">Back to shop</a>
        <div class="item-detail-grid">
          <img src={item.image.src} alt="" class="item-detail-image" />
          <article class="item-detail-card">
            <div class="shop-tag">{item.tag}</div>
            <h1>{item.name}</h1>
            <p class="item-detail-desc">{item.desc}</p>
            <div class="shop-cost">{item.cost}</div>
            <h2>Information</h2>
            <ul>
              {item.details.map((detail) => <li>{detail}</li>)}
            </ul>
          </article>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style is:global>
  .item-detail {
    display: grid;
    gap: 18px;
  }

  .item-detail-grid {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(280px, 1fr);
    gap: 18px;
    align-items: start;
  }

  .item-detail-image,
  .item-detail-card {
    border: 4px solid #050505;
    box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.25);
  }

  .item-detail-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    background: #fff;
  }

  .item-detail-card {
    padding: 18px;
    background: linear-gradient(180deg, #fff, #ffe9a8);
  }

  .item-detail-card h1 {
    margin: 12px 0 8px;
    font-size: clamp(2.2rem, 7vw, 4.2rem);
  }

  .item-detail-card h2 {
    margin: 18px 0 8px;
  }

  .item-detail-card ul {
    margin: 0;
    padding-left: 22px;
  }

  .item-detail-desc {
    font-size: 1.15rem;
  }

  @media (max-width: 720px) {
    .item-detail-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
