---
import Layout from '../layouts/Layout.astro';
import Panel from '../components/Panel.astro';
import TopNav from '../components/TopNav.astro';
---

<Layout title="Submit - Braize" description="Braize submissions are moving to Fillout.">
  <main class="page">
    <TopNav active="dashboard" />

    <Panel id="submit" title="Submissions Under Construction" icon="folder" color="var(--hc-orange)" color2="var(--hc-yellow)">
      <p class="construction-note">
        Project submissions are moving to a Fillout form backed by Airtable.
      </p>
      <p>
        For now: build your browser-adjacent project, keep proof somewhere safe,
        and watch this page for the submit form.
      </p>
      <a class="btn btn-accent" href="/Braize/shop/">See rewards</a>
      <a class="btn" href="/Braize/explore/">Explore projects</a>
    </Panel>
  </main>
</Layout>

<style is:global>
  .construction-note {
    max-width: 58ch;
    padding: 14px 16px;
    background: #fff4a8;
    box-shadow: 5px 5px 0 rgba(0,0,0,0.14);
    transform: rotate(-0.5deg);
  }
</style>
