---
import Layout from '../layouts/Layout.astro';
import Panel from '../components/Panel.astro';
import PixelIcon from '../components/PixelIcon.astro';
---

<Layout title="Dashboard - Braize" description="Manage your Braize projects and journal.">
  <main class="page">
    <div class="dash-header">
      <nav class="breadcrumbs" aria-label="Breadcrumb">
        <a href={import.meta.env.BASE_URL}>Braize</a>
        <span class="sep">›</span>
        <span>Dashboard</span>
      </nav>
    </div>

    <div id="signed-out-notice" class="signed-out" style="display:none;">
      <Panel id="signed-out" title="Not Connected" icon="plug" color="var(--hc-red)" color2="var(--hc-orange)">
        <p>You need to connect your Hack Club account before you can manage projects.</p>
        <a class="btn btn-accent" href={import.meta.env.BASE_URL}>Go connect your account</a>
      </Panel>
    </div>

    <div id="dashboard-body" style="display:none;">
      <section class="dash-hero window">
        <div class="title-bar" style="--title-color: var(--hc-purple); --title-color-2: var(--hc-blue);">
          <div class="title-bar-text">
            <PixelIcon name="monitor" color="#fff" /> Braize Command Center
          </div>
          <div class="title-bar-controls" aria-hidden="true">
            <button type="button">&#95;</button>
            <button type="button">&#9633;</button>
            <button type="button">&#10005;</button>
          </div>
        </div>
        <div class="dash-hero-body">
          <div>
            <p class="eyebrow">PROJECT OPS / HACKATIME SYNC / JOURNAL LOG</p>
            <h1>Dashboard</h1>
            <p class="hero-copy">Track builds, link real coding hours, and keep ship notes in one tiny retro control room.</p>
          </div>
          <div class="hero-terminal" aria-label="Dashboard status terminal">
            <span>C:\BRAIZE&gt; scan projects</span>
            <span>hackatime: ready</span>
            <span>journal: armed</span>
            <span class="terminal-cursor">_</span>
          </div>
        </div>
      </section>

      <!-- Stats taskbar -->
      <div class="stats-bar window">
        <div class="stat">
          <PixelIcon name="folder" color="var(--hc-blue)" />
          <div class="stat-num" id="stat-projects">0</div>
          <div class="stat-label">Projects</div>
        </div>
        <div class="stat">
          <PixelIcon name="monitor" color="var(--hc-green)" />
          <div class="stat-num" id="stat-hours">0.0</div>
          <div class="stat-label">Hours Logged</div>
        </div>
        <div class="stat">
          <PixelIcon name="check" color="var(--hc-yellow)" />
          <div class="stat-num" id="stat-entries">0</div>
          <div class="stat-label">Journal Entries</div>
        </div>
        <div class="stat">
          <PixelIcon name="gift" color="var(--hc-purple)" />
          <div class="stat-num" id="stat-status">—</div>
          <div class="stat-label">Status</div>
        </div>
      </div>

      <Panel id="projects" title="My Projects" icon="folder" color="var(--hc-blue)" color2="var(--hc-cyan)">
        <div class="project-toolbar">
          <div>
            <h2>Build Queue</h2>
            <p>Each folder is one browser project. Link Hackatime once, then hours stay live.</p>
          </div>
          <button type="button" class="btn btn-accent add-project-toggle action-launch" id="add-project-toggle">
            <span id="add-project-toggle-label">+ New Project</span>
          </button>
        </div>

        <form id="new-project-form" class="project-form" hidden>
          <input type="text" name="name" placeholder="Project name" required maxlength="80" />
          <input type="text" name="repo_url" placeholder="Repo URL (optional)" />
          <textarea name="description" placeholder="Description (optional)" rows="2"></textarea>
          <div class="form-actions">
            <button type="submit" class="btn btn-accent">Create</button>
            <button type="button" class="btn" id="cancel-add-project">Cancel</button>
          </div>
        </form>

        <div id="project-list" class="project-list">
          <div class="loading">Loading projects...</div>
        </div>
      </Panel>
    </div>

    <!-- Win95-style confirm dialog -->
    <div class="confirm-overlay" id="confirm-overlay" hidden>
      <div class="confirm-dialog window">
        <div class="title-bar" style="--title-color: var(--hc-red); --title-color-2: var(--hc-orange);">
          <div class="title-bar-text">
            <PixelIcon name="info" color="#fff" /> Confirm
          </div>
        </div>
        <div class="window-body confirm-body">
          <PixelIcon name="info" color="var(--hc-red)" />
          <p id="confirm-message">Are you sure?</p>
        </div>
        <div class="confirm-actions">
          <button type="button" class="btn" id="confirm-yes">Yes</button>
          <button type="button" class="btn" id="confirm-no">No</button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script type="module">
  const { marked } = await import('https://esm.sh/marked@18');

  const WORKER_URL = 'https://braize-worker.braize.workers.dev';

  const account = JSON.parse(localStorage.getItem('braize_hc_account') || 'null');
  const sessionToken = account?.sessionToken;

  const signedOutNotice = document.getElementById('signed-out-notice');
  const dashboardBody = document.getElementById('dashboard-body');
  const projectList = document.getElementById('project-list');
  const newProjectForm = document.getElementById('new-project-form');
  const addProjectToggle = document.getElementById('add-project-toggle');
  const addProjectToggleLabel = document.getElementById('add-project-toggle-label');
  const cancelAddProject = document.getElementById('cancel-add-project');

  if (!sessionToken) {
    signedOutNotice.style.display = 'block';
  } else {
    dashboardBody.style.display = 'block';
    loadProjects();
  }

  function authHeaders(extra = {}) {
    return { Authorization: `Bearer ${sessionToken}`, ...extra };
  }

  async function api(path, options = {}) {
    const res = await fetch(`${WORKER_URL}${path}`, {
      ...options,
      headers: authHeaders({ 'Content-Type': 'application/json', ...(options.headers || {}) }),
    });
    if (!res.ok) throw new Error(`request failed: ${res.status}`);
    return res.json();
  }

  // Hackatime project list cache (5 min)
  const HT_CACHE_KEY = 'braize_hackatime_projects';
  const HT_CACHE_TTL = 5 * 60 * 1000;
  const MAX_JOURNAL_IMAGE_BYTES = 5 * 1024 * 1024;
  let htCache = null;
  let htCacheTs = 0;
  let htInflight = null;
  let htLastError = '';

  async function fetchHackatimeProjects(force = false) {
    const now = Date.now();
    if (!force && htCache && now - htCacheTs < HT_CACHE_TTL) return htCache;
    if (htInflight) return htInflight;

    htInflight = (async () => {
      try {
        const cached = sessionStorage.getItem(HT_CACHE_KEY);
        if (!force && cached) {
          const parsed = JSON.parse(cached);
          if (parsed.ts && now - parsed.ts < HT_CACHE_TTL) {
            htCache = parsed.projects;
            htCacheTs = parsed.ts;
            return htCache;
          }
        }
        const { projects } = await api('/hackatime/projects');
        htCache = projects ?? [];
        htCacheTs = now;
        htLastError = '';
        sessionStorage.setItem(HT_CACHE_KEY, JSON.stringify({ projects: htCache, ts: htCacheTs }));
        return htCache;
      } catch (err) {
        htLastError = err.message;
        htCache = [];
        htCacheTs = now;
        return htCache;
      } finally {
        htInflight = null;
      }
    })();

    return htInflight;
  }

  async function populateHackatimeSelect(select, { force = false } = {}) {
    const current = select.dataset.current || '';
    const projects = await fetchHackatimeProjects(force);
    // preserve current if it isn't in the list (could be a legacy/renamed entry)
    const knownNames = new Set(projects.map((p) => p.name));
    const opts = [];
    opts.push(`<option value="">— not linked —</option>`);
    if (htLastError) {
      opts.push(`<option value="" disabled>Hackatime unavailable (${escapeHtml(htLastError)})</option>`);
    }
    if (current && !knownNames.has(current)) {
      opts.push(`<option value="${escapeHtml(current)}">${escapeHtml(current)} (missing)</option>`);
    }
    for (const p of projects) {
      const hrs = (p.totalSeconds / 3600).toFixed(1);
      opts.push(`<option value="${escapeHtml(p.name)}">${escapeHtml(p.name)} — ${hrs}h</option>`);
    }
    select.innerHTML = opts.join('');
    select.value = current;
    select.disabled = projects.length === 0 && !current;
    if (htLastError) {
      select.title = 'Hackatime project list failed to load. Try refresh.';
    } else if (projects.length === 0) {
      select.title = 'Connect Hackatime and start a timer to populate this list';
    } else {
      select.title = '';
    }
  }

  // Win95-style confirm dialog
  const confirmOverlay = document.getElementById('confirm-overlay');
  const confirmMessage = document.getElementById('confirm-message');
  const confirmYes = document.getElementById('confirm-yes');
  const confirmNo = document.getElementById('confirm-no');

  function win95Confirm(message) {
    return new Promise((resolve) => {
      confirmMessage.textContent = message;
      confirmOverlay.hidden = false;
      const cleanup = () => {
        confirmOverlay.hidden = true;
        confirmYes.removeEventListener('click', onYes);
        confirmNo.removeEventListener('click', onNo);
      };
      const onYes = () => { cleanup(); resolve(true); };
      const onNo = () => { cleanup(); resolve(false); };
      confirmYes.addEventListener('click', onYes);
      confirmNo.addEventListener('click', onNo);
      confirmNo.focus();
    });
  }

  function escapeHtml(str) {
    if (str == null) return '';
    const div = document.createElement('div');
    div.textContent = String(str);
    return div.innerHTML;
  }

  function insertAtCursor(textarea, text) {
    const start = textarea.selectionStart ?? textarea.value.length;
    const end = textarea.selectionEnd ?? textarea.value.length;
    textarea.value = textarea.value.slice(0, start) + text + textarea.value.slice(end);
    const cursor = start + text.length;
    textarea.focus();
    textarea.setSelectionRange(cursor, cursor);
  }

  async function uploadJournalImage(file) {
    const form = new FormData();
    form.append('image', file);
    const res = await fetch(`${WORKER_URL}/uploads`, {
      method: 'POST',
      headers: authHeaders(),
      body: form,
    });
    if (!res.ok) throw new Error(`upload failed: ${res.status}`);
    return res.json();
  }

  function statusColor(status) {
    const s = (status || '').toLowerCase();
    if (s.includes('approved') || s.includes('rewarded') || s.includes('done')) return 'var(--hc-green)';
    if (s.includes('review')) return 'var(--hc-yellow)';
    if (s.includes('reject') || s.includes('fail')) return 'var(--hc-red)';
    return 'var(--hc-cyan)';
  }

  function updateStats(projects) {
    document.getElementById('stat-projects').textContent = projects.length;
    const totalSeconds = projects.reduce((s, p) => s + (p.total_seconds || 0), 0);
    document.getElementById('stat-hours').textContent = (totalSeconds / 3600).toFixed(1);
    const totalEntries = projects.reduce((s, p) => s + (p.journal_count || 0), 0);
    document.getElementById('stat-entries').textContent = totalEntries;
    const statuses = [...new Set(projects.map((p) => p.status).filter(Boolean))];
    document.getElementById('stat-status').textContent = statuses[0] ?? '—';
  }

  async function loadProjects() {
    projectList.innerHTML = '<div class="loading">Loading projects...</div>';
    try {
      const { projects } = await api('/projects');
      renderProjectList(projects);
      updateStats(projects);
    } catch (err) {
      projectList.innerHTML = `<div class="error">Failed to load projects. ${escapeHtml(err.message)}</div>`;
    }
  }

  function renderProjectList(projects) {
    projectList.innerHTML = '';
    if (projects.length === 0) {
      const empty = document.createElement('div');
      empty.className = 'empty-state';
      empty.innerHTML = `
        <div class="empty-art" aria-hidden="true">
          <svg viewBox="0 0 16 16" shape-rendering="crispEdges" width="64" height="64">
            <rect x="1" y="4" width="6" height="2" fill="var(--hc-cyan)"/>
            <rect x="1" y="6" width="14" height="8" fill="var(--hc-cyan)"/>
            <rect x="3" y="8" width="10" height="1" fill="#fff"/>
            <rect x="3" y="10" width="7" height="1" fill="#fff"/>
            <rect x="3" y="12" width="9" height="1" fill="#fff"/>
          </svg>
        </div>
        <h3>No projects yet</h3>
        <p>Click <strong>+ New Project</strong> above to add your first browser build.</p>
      `;
      projectList.appendChild(empty);
      return;
    }
    projects.forEach((p) => projectList.appendChild(renderProject(p)));
  }

  function renderProject(project) {
    const el = document.createElement('div');
    el.className = 'project-card';
    const hours = (project.total_seconds || 0) / 3600;
    const hoursText = hours > 0 ? `${hours.toFixed(1)} hrs` : 'no hours yet';
    const statusColorVal = statusColor(project.status);

    el.innerHTML = `
      <div class="project-tab" style="--project-accent: ${statusColorVal};">
        <div class="project-title-block">
          <span class="project-folder" aria-hidden="true"></span>
          <div>
            <span class="project-name">${escapeHtml(project.name)}</span>
            <span class="project-subtitle">${project.repo_url ? 'repo connected' : 'local build log'}</span>
          </div>
        </div>
        <div class="project-badges">
          <span class="project-hours-chip">${hoursText}</span>
          <span class="project-status">${escapeHtml(project.status || 'in progress')}</span>
        </div>
      </div>
      <div class="project-body">
        <div class="project-summary">
          <div class="project-copy">
            ${project.description ? `<p class="project-desc">${escapeHtml(project.description)}</p>` : '<p class="project-desc muted">No description yet. Add context before review day.</p>'}
            ${project.repo_url ? `<p class="project-repo"><span>Repo</span><a href="${escapeHtml(project.repo_url)}" target="_blank" rel="noopener">${escapeHtml(project.repo_url)}</a></p>` : '<p class="project-repo muted"><span>Repo</span>not added</p>'}
          </div>
          <div class="project-score">
            <strong>${hours > 0 ? hours.toFixed(1) : '0.0'}</strong>
            <span>tracked hrs</span>
          </div>
        </div>

        <div class="project-stats">
          <div class="stat-row">
            <span class="stat-label-inline">Hackatime:</span>
            <select class="hackatime-select" data-project-id="${project.id}" data-current="${escapeHtml(project.hackatime_project_name ?? '')}">
              <option value="">— not linked —</option>
            </select>
            <button type="button" class="btn-mini refresh-hackatime icon-action" title="Refresh project list from Hackatime">Refresh</button>
          </div>
          <div class="hours-display">
            <div class="hours-bar"><div class="hours-fill" id="hours-fill-${project.id}"></div></div>
            <span class="hours-text" id="hours-text-${project.id}">${hoursText}</span>
          </div>
        </div>

        <div class="journal-section">
          <div class="journal-header">
            <div>
              <h4>Journal</h4>
              <span class="journal-kicker">devlog + proof</span>
            </div>
            <button type="button" class="btn-mini toggle-journal action-soft" data-target="journal-form-${project.id}">+ Add Entry</button>
          </div>
          <form class="journal-form" id="journal-form-${project.id}" hidden>
            <input type="text" name="title" placeholder="Entry title (optional)" maxlength="100" />
            <textarea name="body" placeholder="What did you work on? Drop notes, links, screenshots. Markdown supported." rows="5" required></textarea>
            <div class="journal-tools">
              <label class="btn-mini image-upload-btn">
                <span>+ Image</span>
                <input type="file" name="image" accept="image/png,image/jpeg,image/gif,image/webp" />
              </label>
              <span class="journal-help">PNG/JPG/GIF/WebP, max 5 MB. Uploads, then inserts markdown.</span>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn-mini btn-accent-mini action-post">Post Entry</button>
              <button type="button" class="btn-mini cancel-journal action-muted">Cancel</button>
            </div>
          </form>
          <div class="journal-entries" id="journal-${project.id}">
            <div class="loading">Loading journal...</div>
          </div>
        </div>

        <div class="project-footer action-dock">
          <span class="dock-label">Project Controls</span>
          <button type="button" class="btn-mini danger delete-project action-danger">Delete Project</button>
        </div>
      </div>
    `;

    // Hackatime select — auto-save on change
    const select = el.querySelector('.hackatime-select');
    select.addEventListener('change', async () => {
      const value = select.value || null;
      try {
        await api(`/projects/${project.id}`, {
          method: 'PATCH',
          body: JSON.stringify({ hackatime_project_name: value }),
        });
        project.hackatime_project_name = value;
        select.dataset.current = value || '';
        // auto-refresh hours on link
        if (value) {
          const hoursEl = document.getElementById(`hours-text-${project.id}`);
          const fillEl = document.getElementById(`hours-fill-${project.id}`);
          hoursEl.textContent = 'Checking...';
          try {
            const { totalSeconds } = await api(`/projects/${project.id}/hackatime-stats`);
            project.total_seconds = totalSeconds;
            const hrs = totalSeconds / 3600;
            hoursEl.textContent = `${hrs.toFixed(1)} hrs`;
            const pct = Math.min(100, (hrs / 20) * 100);
            fillEl.style.width = pct + '%';
            api('/projects').then(({ projects }) => updateStats(projects));
          } catch {
            hoursEl.textContent = 'no hours yet';
            fillEl.style.width = '0%';
          }
        }
      } catch (err) {
        alert(`Failed to save: ${err.message}`);
        // revert
        select.value = project.hackatime_project_name ?? '';
      }
    });

    // Refresh hackatime list
    el.querySelector('.refresh-hackatime').addEventListener('click', async () => {
      await populateHackatimeSelect(select, { force: true });
    });
    populateHackatimeSelect(select);

    // Delete
    el.querySelector('.delete-project').addEventListener('click', async () => {
      const ok = await win95Confirm(`Delete "${project.name}"? This also deletes its journal entries.`);
      if (!ok) return;
      try {
        await api(`/projects/${project.id}`, { method: 'DELETE' });
        el.remove();
        const { projects } = await api('/projects');
        renderProjectList(projects);
        updateStats(projects);
      } catch (err) {
        alert(`Failed to delete: ${err.message}`);
      }
    });

    // Journal toggle
    const journalForm = el.querySelector(`#journal-form-${project.id}`);
    const toggleJournalBtn = el.querySelector('.toggle-journal');
    toggleJournalBtn.addEventListener('click', () => {
      const hidden = journalForm.hidden;
      journalForm.hidden = !hidden;
      toggleJournalBtn.textContent = hidden ? '× Cancel' : '+ Add Entry';
    });
    el.querySelector('.cancel-journal').addEventListener('click', () => {
      journalForm.hidden = true;
      toggleJournalBtn.textContent = '+ Add Entry';
      journalForm.reset();
    });

    journalForm.image.addEventListener('change', async () => {
      const file = journalForm.image.files?.[0];
      if (!file) return;
      if (!file.type.startsWith('image/')) {
        alert('Pick an image file.');
        journalForm.image.value = '';
        return;
      }
      if (file.size > MAX_JOURNAL_IMAGE_BYTES) {
        alert('Image too large. Keep it under 5 MB.');
        journalForm.image.value = '';
        return;
      }

      const label = journalForm.querySelector('.image-upload-btn');
      const labelText = label.querySelector('span');
      labelText.textContent = 'Uploading...';
      try {
        const { url } = await uploadJournalImage(file);
        const alt = file.name.replace(/\.[^.]+$/, '').replace(/[\[\]()]/g, '').trim() || 'journal image';
        insertAtCursor(journalForm.body, `\n\n![${alt}](${url})\n`);
      } catch (err) {
        alert(`Failed to add image: ${err.message}`);
      } finally {
        labelText.textContent = '+ Image';
        journalForm.image.value = '';
      }
    });

    // Journal submit
    journalForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const title = form.title.value.trim() || null;
      const body = form.body.value.trim();
      if (!body) return;
      try {
        await api(`/projects/${project.id}/journal`, {
          method: 'POST',
          body: JSON.stringify({ title, body }),
        });
        form.reset();
        journalForm.hidden = true;
        toggleJournalBtn.textContent = '+ Add Entry';
        await loadJournal(project.id, el.querySelector(`#journal-${project.id}`));
        const { projects } = await api('/projects');
        updateStats(projects);
      } catch (err) {
        alert(`Failed to post: ${err.message}`);
      }
    });

    // Initial bar fill
    if (hours > 0) {
      const pct = Math.min(100, (hours / 20) * 100);
      requestAnimationFrame(() => {
        document.getElementById(`hours-fill-${project.id}`).style.width = pct + '%';
      });
    }

    // Load journal
    loadJournal(project.id, el.querySelector(`#journal-${project.id}`));

    return el;
  }

  async function loadJournal(projectId, container) {
    try {
      const { entries } = await api(`/projects/${projectId}/journal`);
      container.innerHTML = '';
      if (entries.length === 0) {
        container.innerHTML = '<div class="journal-empty">No entries yet. Ship something and tell the world.</div>';
        return;
      }
      entries.forEach((entry) => {
        const entryEl = document.createElement('div');
        entryEl.className = 'journal-entry';
        const date = new Date(entry.created_at + 'Z');
        const dateStr = date.toLocaleDateString(undefined, { month: 'short', day: 'numeric' });
        const timeStr = date.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
        entryEl.innerHTML = `
          <div class="journal-entry-head">
            ${entry.title ? `<strong class="journal-title">${escapeHtml(entry.title)}</strong>` : '<em class="journal-title muted">untitled</em>'}
            <span class="journal-pill">${dateStr} · ${timeStr}</span>
          </div>
          <div class="journal-body">${marked.parse(entry.body)}</div>
        `;
        container.appendChild(entryEl);
      });
    } catch (err) {
      container.innerHTML = `<div class="error">Failed to load journal. ${escapeHtml(err.message)}</div>`;
    }
  }

  // Add project toggle
  addProjectToggle.addEventListener('click', () => {
    const hidden = newProjectForm.hidden;
    newProjectForm.hidden = !hidden;
    addProjectToggleLabel.textContent = hidden ? '× Close Form' : '+ New Project';
    if (!hidden) {
      newProjectForm.reset();
    } else {
      newProjectForm.querySelector('[name="name"]').focus();
    }
  });
  cancelAddProject.addEventListener('click', () => {
    newProjectForm.hidden = true;
    newProjectForm.reset();
    addProjectToggleLabel.textContent = '+ New Project';
  });

  newProjectForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target;
    const name = form.name.value.trim();
    if (!name) return;
    const repo_url = form.repo_url.value.trim() || null;
    const description = form.description.value.trim() || null;
    try {
      await api('/projects', {
        method: 'POST',
        body: JSON.stringify({ name, repo_url, description }),
      });
      form.reset();
      newProjectForm.hidden = true;
      addProjectToggleLabel.textContent = '+ New Project';
      await loadProjects();
    } catch (err) {
      alert(`Failed to create project: ${err.message}`);
    }
  });
</script>

<style is:global>
  /* Dashboard header */
  .dash-header {
    margin: 24px 0 14px;
  }

  .dash-hero {
    margin-bottom: 18px;
    overflow: hidden;
  }

  .dash-hero-body {
    display: grid;
    grid-template-columns: 1.5fr minmax(220px, 0.8fr);
    gap: 18px;
    padding: 18px;
    background:
      linear-gradient(135deg, rgba(166, 51, 214, 0.2), rgba(91, 192, 222, 0.08)),
      radial-gradient(circle at 12px 12px, rgba(255, 255, 255, 0.18) 0 2px, transparent 2px 24px),
      var(--win-face);
  }

  .eyebrow {
    margin: 0 0 6px;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: bold;
    letter-spacing: 1.4px;
    color: var(--hc-purple);
  }

  .dash-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 9vw, 5.6rem);
    color: #fff;
    text-shadow:
      3px 3px 0 var(--hc-purple),
      6px 6px 0 rgba(0, 0, 0, 0.35),
      0 0 18px rgba(91, 192, 222, 0.65);
  }

  .hero-copy {
    max-width: 560px;
    margin: 8px 0 0;
    color: rgba(0, 0, 0, 0.78);
    font-weight: bold;
  }

  .hero-terminal {
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    padding: 14px;
    min-height: 130px;
    background: #050505;
    color: var(--hc-green);
    font-family: 'Lucida Console', monospace;
    font-size: 0.82rem;
    box-shadow:
      inset 1px 1px #000,
      inset -1px -1px var(--win-light-highlight),
      5px 5px 0 rgba(0, 0, 0, 0.28);
  }

  .terminal-cursor {
    animation: blink 1s steps(1) infinite;
  }

  .breadcrumbs {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.85);
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .breadcrumbs a {
    color: var(--hc-yellow);
    text-decoration: none;
  }
  .breadcrumbs a:hover {
    text-decoration: underline;
  }
  .breadcrumbs .sep {
    opacity: 0.6;
  }

  /* Stats taskbar */
  .stats-bar {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 8px;
    padding: 8px;
    margin-bottom: 20px;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.08), transparent 40%, rgba(255, 255, 255, 0.22)),
      var(--win-face);
  }
  .stat {
    position: relative;
    padding: 16px 12px 14px;
    text-align: center;
    background:
      linear-gradient(180deg, #fff 0 18%, var(--win-face) 18% 100%);
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-light-highlight),
      3px 3px 0 rgba(0, 0, 0, 0.16);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat::before {
    content: '';
    position: absolute;
    inset: 4px 4px auto;
    height: 3px;
    background: linear-gradient(90deg, var(--hc-red), var(--hc-orange), var(--hc-yellow), var(--hc-green), var(--hc-cyan), var(--hc-purple));
  }

  .stat svg.pixel-icon {
    width: 28px;
    height: 28px;
    image-rendering: pixelated;
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: 2.35rem;
    line-height: 1;
    color: #101010;
    margin-top: 2px;
    text-shadow: 2px 2px 0 rgba(91, 192, 222, 0.25);
  }
  .stat-label {
    font-family: var(--font-body);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: var(--win-shadow);
  }

  /* Add project toggle */
  .add-project-toggle {
    flex-shrink: 0;
  }

  .action-launch {
    position: relative;
    padding: 12px 18px 12px 44px;
    min-height: 46px;
    background:
      linear-gradient(180deg, var(--hc-yellow), var(--hc-orange));
    text-transform: uppercase;
    letter-spacing: 0.6px;
    box-shadow:
      inset -1px -1px var(--win-dark-shadow),
      inset 1px 1px var(--win-light-highlight),
      inset -2px -2px rgba(0,0,0,0.28),
      inset 2px 2px rgba(255,255,255,0.35),
      5px 5px 0 rgba(0,0,0,0.25);
  }

  .action-launch::before {
    content: '';
    position: absolute;
    left: 13px;
    top: 50%;
    width: 18px;
    height: 18px;
    transform: translateY(-50%);
    background:
      linear-gradient(#111, #111) 7px 2px / 4px 14px no-repeat,
      linear-gradient(#111, #111) 2px 7px / 14px 4px no-repeat;
  }

  .action-launch:hover {
    transform: translate(-1px, -1px);
    box-shadow:
      inset -1px -1px var(--win-dark-shadow),
      inset 1px 1px var(--win-light-highlight),
      inset -2px -2px rgba(0,0,0,0.28),
      inset 2px 2px rgba(255,255,255,0.35),
      7px 7px 0 rgba(0,0,0,0.25);
  }

  .project-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 14px;
    padding: 12px;
    background:
      linear-gradient(90deg, rgba(241, 196, 15, 0.45), rgba(91, 192, 222, 0.22)),
      var(--win-face);
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-light-highlight);
  }

  .project-toolbar h2 {
    margin: 0 0 2px;
  }

  .project-toolbar p {
    margin: 0;
    max-width: 520px;
    color: rgba(0, 0, 0, 0.68);
    font-size: 0.88rem;
  }
  .project-form[hidden] {
    display: none;
  }
  .project-form {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 18px;
    padding: 14px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(91, 192, 222, 0.12)),
      #fff;
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-dark-shadow);
  }
  .project-form input,
  .project-form textarea,
  .journal-form input,
  .journal-form textarea,
  .hackatime-select {
    font-family: var(--font-body);
    font-size: 0.9rem;
    padding: 6px 8px;
    background: var(--win-face);
    box-shadow:
      inset 1px 1px var(--win-dark-shadow),
      inset -1px -1px var(--win-light-highlight);
    border: none;
  }
  .form-actions {
    display: flex;
    gap: 6px;
  }

  /* Project list */
  .project-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .project-list .loading {
    padding: 20px;
    text-align: center;
    color: var(--win-shadow);
    font-style: italic;
  }
  .project-list .error {
    padding: 14px;
    background: #fee;
    color: var(--hc-red);
    box-shadow:
      inset 1px 1px var(--hc-red),
      inset -1px -1px #fcc;
  }

  /* Empty state */
  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    padding: 40px 20px;
    background: #fff;
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-dark-shadow);
  }
  .empty-art {
    margin-bottom: 12px;
  }
  .empty-state h3 {
    margin-bottom: 6px;
  }
  .empty-state p {
    color: var(--win-shadow);
    font-size: 0.9rem;
  }

  /* Project card — folder tab style */
  .project-card {
    position: relative;
    background: var(--win-face);
    border: 0;
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-dark-shadow),
      10px 10px 0 rgba(0, 0, 0, 0.24);
    overflow: hidden;
    min-height: 100%;
    transition: transform 0.1s ease, box-shadow 0.1s ease;
  }

  .project-card::after {
    content: '';
    position: absolute;
    right: 18px;
    top: 58px;
    width: 96px;
    height: 76px;
    opacity: 0.06;
    background:
      linear-gradient(var(--project-accent, var(--hc-blue)), var(--project-accent, var(--hc-blue))) 0 18px / 96px 58px no-repeat,
      linear-gradient(var(--project-accent, var(--hc-blue)), var(--project-accent, var(--hc-blue))) 0 0 / 42px 24px no-repeat;
    pointer-events: none;
  }

  .project-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 7px;
    background: linear-gradient(180deg, var(--project-accent, var(--hc-blue)), var(--hc-yellow), var(--hc-purple));
    z-index: 2;
  }

  .project-card:hover {
    transform: translate(-2px, -2px);
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-dark-shadow),
      14px 14px 0 rgba(0, 0, 0, 0.24),
      0 0 22px rgba(91, 192, 222, 0.22);
  }
  .project-tab {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    min-height: 58px;
    padding: 10px 12px;
    color: #fff;
    font-family: var(--font-body);
    background:
      linear-gradient(90deg, var(--project-accent, var(--hc-blue)), rgba(0,0,0,0.72)),
      repeating-linear-gradient(90deg, rgba(255,255,255,0.12) 0 2px, transparent 2px 10px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -1px 0 rgba(0, 0, 0, 0.25);
  }

  .project-title-block {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
  }

  .project-folder {
    position: relative;
    width: 38px;
    height: 30px;
    flex-shrink: 0;
    background: var(--hc-yellow);
    box-shadow:
      inset -2px -2px rgba(0, 0, 0, 0.25),
      inset 2px 2px rgba(255, 255, 255, 0.55),
      3px 3px 0 rgba(0, 0, 0, 0.25);
  }

  .project-folder::before {
    content: '';
    position: absolute;
    left: 0;
    top: -7px;
    width: 18px;
    height: 9px;
    background: var(--hc-yellow);
    box-shadow: inset 2px 2px rgba(255, 255, 255, 0.55);
  }

  .project-name {
    display: block;
    font-weight: bold;
    font-size: 1.08rem;
    max-width: 48vw;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: 1px 1px 0 rgba(0, 0, 0, 0.45);
  }

  .project-subtitle {
    display: block;
    margin-top: 2px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .project-badges {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .project-hours-chip {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--hc-green);
    background: #000;
    padding: 2px 8px;
    box-shadow: inset 0 0 0 1px var(--hc-green);
  }
  .project-status {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: bold;
    background: rgba(255, 255, 255, 0.16);
    padding: 4px 8px;
    box-shadow:
      inset -1px -1px rgba(0,0,0,0.38),
      inset 1px 1px rgba(255,255,255,0.25);
  }
  .project-body {
    position: relative;
    z-index: 1;
    padding: 14px;
    background:
      linear-gradient(180deg, rgba(255,255,255,0.45), transparent 90px),
      var(--win-face);
  }

  .project-summary {
    display: grid;
    grid-template-columns: 1fr 120px;
    gap: 12px;
    align-items: stretch;
    margin-bottom: 12px;
  }

  .project-copy {
    min-width: 0;
    padding: 12px;
    background: #fff;
    box-shadow:
      inset 1px 1px var(--win-dark-shadow),
      inset -1px -1px var(--win-light-highlight);
  }

  .project-score {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 10px;
    background: #080808;
    color: var(--hc-green);
    text-align: center;
    box-shadow:
      inset 1px 1px #000,
      inset -1px -1px var(--win-light-highlight);
  }

  .project-score strong {
    font-family: var(--font-display);
    font-size: 2.8rem;
    line-height: 0.9;
    font-weight: normal;
    text-shadow: 0 0 10px rgba(51, 214, 166, 0.5);
  }

  .project-score span {
    margin-top: 5px;
    color: rgba(51, 214, 166, 0.78);
    font-size: 0.72rem;
    text-transform: uppercase;
  }
  .project-desc {
    margin: 0 0 8px;
    color: var(--win-text);
  }

  .project-desc.muted,
  .project-repo.muted {
    color: var(--win-shadow);
    font-style: italic;
  }

  .project-repo {
    margin: 0 0 10px;
    font-size: 0.85rem;
    display: flex;
    gap: 8px;
    align-items: baseline;
    min-width: 0;
  }

  .project-repo span {
    flex-shrink: 0;
    padding: 1px 6px;
    background: var(--hc-cyan);
    color: #001;
    font-weight: bold;
    text-transform: uppercase;
    font-size: 0.68rem;
  }

  .project-repo a {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Project stats row */
  .project-stats {
    background:
      repeating-linear-gradient(90deg, rgba(255,255,255,0.32) 0 1px, transparent 1px 8px),
      linear-gradient(135deg, rgba(91, 192, 222, 0.24), rgba(255,255,255,0.12)),
      var(--win-face);
    display: grid;
    grid-template-columns: minmax(220px, 0.9fr) 1fr;
    gap: 12px;
    align-items: center;
    padding: 12px;
    margin: 10px 0;
    box-shadow:
      inset 1px 1px var(--win-dark-shadow),
      inset -1px -1px var(--win-light-highlight);
  }
  .stat-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 0;
  }
  .stat-label-inline {
    font-size: 0.8rem;
    font-weight: bold;
    color: var(--win-shadow);
  }
  .hackatime-input {
    flex: 1;
    min-width: 120px;
    font-size: 0.85rem;
  }

  .hackatime-select {
    flex: 1;
    min-width: 120px;
    font-size: 0.85rem;
    appearance: none;
    background:
      linear-gradient(45deg, transparent 50%, var(--win-text) 50%) calc(100% - 13px) 50% / 6px 6px no-repeat,
      linear-gradient(-45deg, transparent 50%, var(--win-text) 50%) calc(100% - 9px) 50% / 6px 6px no-repeat,
      var(--win-face);
    padding-right: 28px;
  }

  .icon-action {
    min-height: 30px;
    padding-inline: 12px;
    background: linear-gradient(180deg, #fff, var(--hc-cyan));
    color: #001;
    text-transform: uppercase;
    letter-spacing: 0.4px;
  }

  .icon-action::before {
    content: '↻';
    margin-right: 5px;
    color: var(--hc-blue);
  }
  .hours-display {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .hours-bar {
    flex: 1;
    height: 12px;
    background: #000;
    box-shadow:
      inset 1px 1px var(--win-dark-shadow),
      inset -1px -1px var(--win-light-highlight);
    overflow: hidden;
    min-width: 60px;
  }
  .hours-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--hc-green), var(--hc-cyan));
    box-shadow: 0 0 6px var(--hc-green);
    transition: width 0.6s ease;
  }
  .hours-text {
    font-family: var(--font-display);
    font-size: 0.95rem;
    color: var(--hc-green);
    min-width: 70px;
    text-align: right;
  }

  /* Mini buttons */
  .btn-mini {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: bold;
    padding: 4px 8px;
    background: var(--win-face);
    color: var(--win-text);
    text-decoration: none;
    box-shadow:
      inset -1px -1px var(--win-dark-shadow),
      inset 1px 1px var(--win-light-highlight),
      inset -2px -2px var(--win-shadow),
      inset 2px 2px var(--win-highlight);
    cursor: pointer;
    border: none;
    transition: transform 0.08s ease, filter 0.08s ease;
  }

  .btn-mini:hover {
    transform: translate(-1px, -1px);
    filter: saturate(1.15);
  }
  .btn-mini:active {
    box-shadow:
      inset 1px 1px var(--win-dark-shadow),
      inset -1px -1px var(--win-light-highlight),
      inset 2px 2px var(--win-shadow),
      inset -2px -2px var(--win-highlight);
  }
  .btn-mini.danger {
    color: var(--hc-red);
  }
  .btn-mini.danger:hover {
    background: var(--hc-red);
    color: #fff;
  }
  .btn-accent-mini {
    background: var(--hc-yellow);
  }

  .action-soft {
    background: linear-gradient(180deg, #fff, var(--hc-purple));
    color: #fff;
    text-shadow: 1px 1px 0 rgba(0,0,0,0.45);
  }

  .action-post {
    min-width: 110px;
    background: linear-gradient(180deg, var(--hc-green), var(--hc-cyan));
    color: #001;
  }

  .action-muted {
    color: var(--win-shadow);
  }

  .action-danger {
    background: linear-gradient(180deg, #fff, #ffd6dc);
  }

  /* Journal section */
  .journal-section {
    margin-top: 14px;
    border-top: 2px dotted var(--win-shadow);
    padding-top: 12px;
    background:
      linear-gradient(180deg, rgba(166, 51, 214, 0.08), transparent 90px);
  }
  .journal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .journal-kicker {
    display: block;
    margin-top: -4px;
    color: var(--win-shadow);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }
  .journal-header h4 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 1.55rem;
    font-weight: normal;
    letter-spacing: 0.5px;
    color: var(--hc-purple);
    text-shadow: 1px 1px 0 #fff;
  }
  .journal-form {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 14px;
    padding: 12px;
    background:
      linear-gradient(135deg, #fff 0 58%, rgba(241, 196, 15, 0.2)),
      var(--win-face);
    box-shadow:
      inset 1px 1px var(--win-dark-shadow),
      inset -1px -1px var(--win-light-highlight),
      4px 4px 0 rgba(0, 0, 0, 0.18);
  }

  .journal-form textarea {
    min-height: 120px;
    resize: vertical;
    line-height: 1.45;
  }

  .journal-tools {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 6px;
    background: rgba(0, 0, 0, 0.06);
    box-shadow:
      inset 1px 1px var(--win-shadow),
      inset -1px -1px var(--win-light-highlight);
  }

  .image-upload-btn {
    position: relative;
    overflow: hidden;
    background: var(--hc-cyan);
  }

  .image-upload-btn input {
    position: absolute;
    inset: 0;
    opacity: 0;
    cursor: pointer;
  }

  .journal-help {
    color: var(--win-shadow);
    font-size: 0.74rem;
  }
  .journal-empty {
    color: rgba(0, 0, 0, 0.68);
    padding: 16px 12px;
    text-align: center;
    font-size: 0.85rem;
    background:
      repeating-linear-gradient(-45deg, rgba(255,255,255,0.55) 0 6px, rgba(0,0,0,0.03) 6px 12px),
      var(--win-face);
    box-shadow:
      inset 1px 1px var(--win-shadow),
      inset -1px -1px var(--win-light-highlight);
  }
  .journal-entry {
    position: relative;
    background:
      linear-gradient(90deg, var(--hc-yellow) 0 5px, transparent 5px),
      linear-gradient(180deg, #fff 0, #fffdf0 100%);
    padding: 12px 12px 12px 16px;
    margin-bottom: 12px;
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-light-highlight),
      5px 5px 0 rgba(0, 0, 0, 0.14);
  }

  .journal-entry::before {
    content: 'LOG';
    position: absolute;
    right: 10px;
    bottom: 8px;
    font-family: var(--font-display);
    font-size: 2rem;
    color: rgba(166, 51, 214, 0.08);
    pointer-events: none;
  }
  .journal-entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
    border-bottom: 1px dotted rgba(0, 0, 0, 0.22);
    padding-bottom: 6px;
  }
  .journal-title {
    font-size: 0.95rem;
    color: #111;
  }
  .journal-title.muted {
    color: var(--win-shadow);
    font-weight: normal;
  }
  .journal-pill {
    font-family: var(--font-display);
    font-size: 0.8rem;
    background: #000;
    color: var(--hc-cyan);
    padding: 1px 6px;
    box-shadow:
      inset 0 0 0 1px var(--hc-cyan);
  }
  .journal-body {
    position: relative;
    z-index: 1;
    font-size: 0.9rem;
    line-height: 1.5;
  }
  .journal-body p {
    margin: 0.45em 0;
  }
  .journal-body code {
    background: rgba(0, 0, 0, 0.1);
    padding: 1px 4px;
    font-size: 0.85em;
  }

  .journal-body a {
    color: var(--hc-blue);
    font-weight: bold;
  }

  .journal-body img {
    display: block;
    max-width: 100%;
    max-height: 360px;
    margin: 10px 0;
    object-fit: contain;
    background: #111;
    padding: 4px;
    image-rendering: auto;
    box-shadow:
      inset -1px -1px var(--win-dark-shadow),
      inset 1px 1px var(--win-light-highlight),
      4px 4px 0 rgba(0, 0, 0, 0.22);
  }

  /* Project footer */
  .project-footer {
    margin-top: 12px;
    padding-top: 10px;
