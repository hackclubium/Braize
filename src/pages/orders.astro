---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import Panel from '../components/Panel.astro';
---

<Layout title="Orders - Braize" description="Braize reward status is under construction.">
  <main class="page">
    <TopNav active="orders" />

    <Panel id="orders" title="Reward Status Under Construction" icon="gift" color="var(--hc-purple)" color2="var(--hc-red)">
      <p class="construction-note">
        Reward tracking will come after submissions are reviewed from the form.
      </p>
      <p>For now, submitted projects and reward review are not shown on this page.</p>
      <a class="btn btn-accent" href="/Braize/shop/">See reward tiers</a>
    </Panel>
  </main>
</Layout>

<style is:global>
  .construction-note {
    max-width: 58ch;
    padding: 14px 16px;
    background: #fff4a8;
    box-shadow: 5px 5px 0 rgba(0,0,0,0.14);
    transform: rotate(-0.5deg);
  }
</style>
