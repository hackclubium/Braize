---
import PixelIcon from './PixelIcon.astro';

const HACKCLUB_AUTH_CLIENT_ID = '5d55fc042761a61272e88549fc0dbadf';
const WORKER_URL = 'https://braize-worker.braize.workers.dev';
const REDIRECT_URI = 'https://hackclubium.github.io/Braize/';
---

<div class="auth-block">
  <div class="auth-row">
    <PixelIcon name="hackclub" />
    <div class="auth-info">
      <strong>Hack Club Account</strong>
      <p class="auth-status" id="hc-status">Not connected.</p>
      <form class="name-form" id="hc-name-form" hidden>
        <input id="hc-name-input" name="display_name" maxlength="60" placeholder="Display name" />
        <button type="submit" class="btn btn-mini">Save name</button>
      </form>
    </div>
    <button type="button" class="btn" id="hc-connect-btn">Connect</button>
  </div>
</div>

<script define:vars={{ HACKCLUB_AUTH_CLIENT_ID, WORKER_URL, REDIRECT_URI }}>
  const hcStatusEl = document.getElementById('hc-status');
  const hcConnectBtn = document.getElementById('hc-connect-btn');
  const hcNameForm = document.getElementById('hc-name-form');
  const hcNameInput = document.getElementById('hc-name-input');

  function getStoredAccount() {
    const stored = localStorage.getItem('braize_hc_account');
    return stored ? JSON.parse(stored) : null;
  }

  function saveStoredAccount(account) {
    localStorage.setItem('braize_hc_account', JSON.stringify(account));
  }

  function displayName(account) {
    return account?.displayName ?? account?.display_name ?? account?.name ?? 'Hack Clubber';
  }

  function renderHcStatus() {
    const account = getStoredAccount();
    if (account) {
      const { verificationStatus, yswsEligible } = account;
      const idVerified = verificationStatus === 'verified';
      hcStatusEl.textContent = `Connected as ${displayName(account)}. ID: ${
        idVerified ? 'Verified' : verificationStatus ?? 'unverified'
      }. YSWS eligible: ${yswsEligible ? 'Yes' : 'No'}.`;
      hcNameInput.value = account.displayName ?? account.display_name ?? '';
      hcNameForm.hidden = false;
      hcConnectBtn.textContent = 'Reconnect';
    } else {
      hcStatusEl.textContent = 'Not connected.';
      hcNameForm.hidden = true;
      hcConnectBtn.textContent = 'Connect';
    }
  }

  function startOauth() {
    const state = `hackclub:${crypto.randomUUID()}`;
    sessionStorage.setItem('braize_oauth_state', state);
    const params = new URLSearchParams({
      client_id: HACKCLUB_AUTH_CLIENT_ID,
      redirect_uri: REDIRECT_URI,
      response_type: 'code',
      scope: 'openid name verification_status slack_id',
      state,
    });
    window.location.href = `https://auth.hackclub.com/oauth/authorize?${params.toString()}`;
  }

  async function handleOauthReturn() {
    const url = new URL(window.location.href);
    const code = url.searchParams.get('code');
    const state = url.searchParams.get('state');
    if (!code) return;

    const expectedState = sessionStorage.getItem('braize_oauth_state');
    sessionStorage.removeItem('braize_oauth_state');
    url.searchParams.delete('code');
    url.searchParams.delete('state');
    window.history.replaceState({}, '', url.toString());

    if (!state || state !== expectedState) {
      hcStatusEl.textContent = 'Login failed (state mismatch). Try again.';
      return;
    }

    hcStatusEl.textContent = 'Finishing login...';
    try {
      const res = await fetch(`${WORKER_URL}/oauth/hackclub`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });
      if (!res.ok) {
        hcStatusEl.textContent = 'Login failed. Try again.';
        return;
      }
      saveStoredAccount(await res.json());
      renderHcStatus();
    } catch {
      hcStatusEl.textContent = 'Login failed. Try again.';
    }
  }

  async function refreshMe() {
    const account = getStoredAccount();
    if (!account?.sessionToken) return;

    try {
      const res = await fetch(`${WORKER_URL}/me`, {
        headers: { Authorization: `Bearer ${account.sessionToken}` },
      });
      if (!res.ok) return;
      const { user } = await res.json();
      saveStoredAccount({ ...account, displayName: user.display_name, name: user.name });
      renderHcStatus();
    } catch {}
  }

  async function saveName(event) {
    event.preventDefault();
    const account = getStoredAccount();
    if (!account?.sessionToken) return;

    hcStatusEl.textContent = 'Saving name...';
    try {
      const res = await fetch(`${WORKER_URL}/me`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${account.sessionToken}`,
        },
        body: JSON.stringify({ display_name: hcNameInput.value }),
      });
      if (!res.ok) throw new Error('name save failed');
      const { user } = await res.json();
      saveStoredAccount({ ...account, displayName: user.display_name, name: user.name });
      renderHcStatus();
    } catch {
      hcStatusEl.textContent = 'Name save failed. Reconnect, then try again.';
    }
  }

  hcConnectBtn.addEventListener('click', startOauth);
  hcNameForm.addEventListener('submit', saveName);
  renderHcStatus();
  refreshMe();
  handleOauthReturn();
</script>

<style>
  .auth-row {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    background: #fff;
    padding: 12px;
    box-shadow: inset -1px -1px var(--win-shadow), inset 1px 1px var(--win-dark-shadow);
  }
  .auth-info {
    flex: 1;
    min-width: 0;
  }
  .auth-status {
    margin: 2px 0 0;
    font-size: 0.85rem;
  }
  .name-form {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 8px;
  }
  .name-form input {
    min-width: 180px;
    flex: 1;
    padding: 7px 8px;
    border: 0;
    font: inherit;
    background: #fffbe0;
    box-shadow: inset -1px -1px var(--win-light-highlight), inset 1px 1px var(--win-dark-shadow);
  }
  .auth-row .btn {
    flex-shrink: 0;
  }
</style>

<style is:global>
  .auth-row .pixel-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    image-rendering: pixelated;
    margin-top: 2px;
  }
</style>
