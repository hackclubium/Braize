---
interface Props {
  active: 'dashboard' | 'shop' | 'orders' | 'faq' | 'guides';
  crumb?: string;
}

const { active, crumb } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const tabs = [
  { key: 'dashboard', label: 'Submit', href: `${base}/dashboard/` },
  { key: 'guides', label: 'Guides', href: `${base}/guides/` },
  { key: 'faq', label: 'FAQ', href: `${base}/faq/` },
  { key: 'shop', label: 'Shop', href: `${base}/shop/` },
  { key: 'orders', label: 'Status', href: `${base}/orders/` },
];
---

<nav class="top-nav" aria-label="App navigation">
  <a class="top-nav-home" href={`${base}/`}>Braize</a>
  {tabs.map((tab) => (
    <a
      href={tab.href}
      class={`top-nav-tab${tab.key === active ? ' active' : ''}`}
      aria-current={tab.key === active ? 'page' : undefined}
    >
      {tab.label}
    </a>
  ))}
  {crumb && <span class="top-nav-crumb">› {crumb}</span>}
</nav>

<style is:global>
  .top-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    padding: 8px 10px;
    margin-top: 14px;
    background: #050505;
    box-shadow: inset -1px -1px rgba(255, 255, 255, 0.08), inset 1px 1px rgba(0, 0, 0, 0.6);
  }

  .top-nav-home {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--hc-yellow);
    text-decoration: underline;
    margin-right: 8px;
  }

  .top-nav-tab {
    padding: 5px 10px;
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--hc-yellow);
    text-decoration: none;
    background: #111;
    box-shadow: inset -1px -1px rgba(0, 0, 0, 0.6), inset 1px 1px rgba(255, 255, 255, 0.08);
  }

  .top-nav-tab:hover {
    color: #fff;
  }

  .top-nav-tab.active {
    color: #111;
    background: var(--hc-yellow);
    box-shadow: inset 1px 1px rgba(0, 0, 0, 0.4), inset -1px -1px rgba(255, 255, 255, 0.5);
  }

  .top-nav-crumb {
    font-family: var(--font-display);
    font-size: 1rem;
    color: #fff;
  }
</style>
