---
const steps = [
  { title: 'Build', body: 'Start from scratch. Any language, any stack, any editor.' },
  { title: 'Ship', body: 'Push your code, write a README explaining what it does, and submit the form below.' },
  { title: 'Get Reviewed', body: 'A Hack Clubber checks that it runs and that it actually does something browser-related.' },
  { title: 'Get Rewarded', body: 'Approved projects get their prize shipped straight to your door.' },
];
---

<ol class="timeline">
  {steps.map((step) => (
    <li>
      <strong>{step.title}.</strong> {step.body}
    </li>
  ))}
</ol>
