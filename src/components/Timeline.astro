---
const steps = [
  { title: 'Build', body: 'Use whatever stack you like. Small is fine if it works.' },
  { title: 'Log', body: 'Post quick notes as you go so reviewers can see the trail.' },
  { title: 'Ship', body: 'Push code, add a README, and share a public link.' },
  { title: 'Get Rewarded', body: 'If it runs and fits the theme, Hack Club sends prizes.' },
];
---

<ol class="timeline">
  {steps.map((step) => (
    <li>
      <strong>{step.title}.</strong> {step.body}
    </li>
  ))}
</ol>
