---
const steps = [
  { title: 'Build', body: 'Use whatever stack you like. Small is fine if it works.' },
  { title: 'Log', body: 'Keep quick notes and proof as you go so reviewers can see the trail.' },
  { title: 'Submit', body: 'Use the Hack Club submission form. It sends entries into Airtable.' },
  { title: 'Get Rewarded', body: 'If it runs and fits the theme, Hack Club sends prizes.' },
];
---

<ol class="timeline">
  {steps.map((step) => (
    <li>
      <strong>{step.title}.</strong> {step.body}
    </li>
  ))}
</ol>
