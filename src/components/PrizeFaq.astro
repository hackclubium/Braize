---
import PixelIcon from './PixelIcon.astro';

const tiers = [
  {
    icon: 'sticker',
    color: 'var(--hc-cyan)',
    title: 'Ship Anything',
    body: 'Submit something that actually runs and we send you a pack of browser-themed stickers.',
  },
  {
    icon: 'mouse',
    color: 'var(--hc-green)',
    title: 'Ship Something',
    body: 'Meet the bar and we send you a high-quality wireless mouse. Because you’ll be doing a lot of browsing.',
  },
  {
    icon: 'globe',
    color: 'var(--hc-blue)',
    title: 'Ship Something Great',
    body: 'Standout submissions get a free domain name plus a year of hosting: your own place on the web.',
  },
  {
    icon: 'monitor',
    color: 'var(--hc-purple)',
    title: 'Ship Something Exceptional',
    body: 'A polished, from-scratch browser engine (or equally ambitious project) earns a portable monitor. More screen, more tabs.',
  },
];

const faqs = [
  {
    q: 'What counts as "browser-related"?',
    a: 'Anything that involves browsing: a browser, an extension, a browsing buddy, or something weirder. See the What Counts section above.',
  },
  {
    q: 'Do I need experience building browser engines?',
    a: "No. Start from wherever you are. A simple project that actually ships beats an ambitious one that doesn't.",
  },
  {
    q: 'What language should I use?',
    a: 'Any language you want. C++ and Rust are common for real browser engines, but extensions and browsing buddies can be built in anything.',
  },
  {
    q: 'What decides which prize tier I get?',
    a: 'Reviewers judge how ambitious and complete the project is, from "it runs" all the way up to a polished from-scratch browser engine.',
  },
  {
    q: "What's the deadline?",
    a: 'Submit when your project is ready. If a final cutoff gets announced, it will be posted in Slack and reflected here.',
  },
  {
    q: 'How do I submit?',
    a: 'Open the dashboard, create a project, add journal proof, then share the public project page for review.',
  },
];
---

<div class="prize-block">
  <div class="card-grid">
    {tiers.map((tier) => (
      <div class="card" style={`--glow: ${tier.color}`}>
        <PixelIcon name={tier.icon} color={tier.color} />
        <h3>{tier.title}</h3>
        <p>{tier.body}</p>
      </div>
    ))}
  </div>
  <span class="placeholder-note">Prize tier depends on review: working builds qualify, standout builds earn bigger rewards.</span>
</div>

<div class="faq-list">
  {faqs.map((item) => (
    <details class="faq-item">
      <summary>{item.q}</summary>
      <p class="faq-answer">{item.a}</p>
    </details>
  ))}
</div>
