---

import PixelIcon from './PixelIcon.astro';

const tabs = [
  { href: '#about', label: 'About' },
  { href: '#what-counts', label: 'What Counts' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '#connect', label: 'Connect' },
  { href: '#prize', label: 'Prize + FAQ' },
];
---

<div class="window hero-window">
  <div class="title-bar" style="--title-color: var(--hc-red); --title-color-2: var(--hc-orange);">
    <div class="title-bar-text">
      <PixelIcon name="folder" /> Braize.exe
    </div>
    <div class="title-bar-controls">
      <button type="button" aria-label="Minimize">&#95;</button>
      <button type="button" aria-label="Maximize">&#9633;</button>
      <button type="button" class="close-btn" aria-label="Close" id="close-btn">&#10005;</button>
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <span>&#9733; Hack Club YSWS &#9733; You Ship, We Ship &#9733; Build a browser. Ship it. Get rewarded. &#9733; #braize on Slack &#9733; Submit when your build is ready &#9733;</span>
  </div>

  <div class="loading-bar" id="loading-bar">
    <div class="loading-bar-inner" id="loading-bar-inner"></div>
  </div>

  <nav class="tab-strip" aria-label="Section navigation" id="section-nav">
    {tabs.map((tab) => <a href={tab.href}>{tab.label}</a>)}
  </nav>

  <div class="address-bar-row">
    <button type="button" class="nav-btn" aria-label="Back" disabled>&#8592;</button>
    <button type="button" class="nav-btn" aria-label="Forward" disabled>&#8594;</button>
    <button type="button" class="nav-btn" aria-label="Refresh" disabled>&#8635;</button>
    <div class="address-bar bevel-in">
      <span class="label">Address:</span>
      <span class="typed" id="typed-text"></span><span class="caret"></span>
    </div>
  </div>

  <div class="window-body hero-body">
    <h1 id="hero-heading">Ship anything browser-related.</h1>
    <p class="hero-sub">
      Braize is a Hack Club YSWS. Build a browser, an extension, a browsing
      buddy, or whatever "browsing" means to you. Ship it, and we'll ship you
      something back.
    </p>
    <div class="hero-actions">
      <a class="btn btn-accent" href="/Braize/dashboard/">Open Dashboard</a>
      <a class="btn" href="#how-it-works">See How It Works</a>
    </div>
  </div>

  <div class="status-bar" id="status-bar">Ready.</div>
</div>

<script>
  const phrases = [
    'a browser...',
    'a browser extension...',
    'a browsing buddy...',
    'literally anything with "browse" in it...',
  ];

  const el = document.getElementById('typed-text');

  if (el) {
    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;

    const tick = () => {
      const phrase = phrases[phraseIndex];

      if (!deleting) {
        charIndex++;
        el.textContent = phrase.slice(0, charIndex);
        if (charIndex === phrase.length) {
          deleting = true;
          setTimeout(tick, 1400);
          return;
        }
      } else {
        charIndex--;
        el.textContent = phrase.slice(0, charIndex);
        if (charIndex === 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
        }
      }

      setTimeout(tick, deleting ? 40 : 70);
    };

    tick();
  }

  const closeBtn = document.getElementById('close-btn');
  const statusBar = document.getElementById('status-bar');

  closeBtn?.addEventListener('click', () => {
    document.body.classList.add('shake');
    setTimeout(() => document.body.classList.remove('shake'), 400);

    const heading = document.getElementById('hero-heading');
    if (heading) {
      heading.setAttribute('data-text', heading.textContent || '');
      heading.classList.add('glitch');
      setTimeout(() => {
        heading.classList.remove('glitch');
        heading.removeAttribute('data-text');
      }, 400);
    }

    closeBtn.classList.remove('wobble');
    void closeBtn.offsetWidth;
    closeBtn.classList.add('wobble');

    if (statusBar) statusBar.textContent = '⚠ Do not close this window.';
    setTimeout(() => {
      if (statusBar) statusBar.textContent = 'Ready.';
    }, 2000);
  });

  const navLinks = document.querySelectorAll('#section-nav a');
  const sections = Array.from(navLinks)
    .map((link) => document.getElementById(link.getAttribute('href').slice(1)))
    .filter(Boolean);

  if (sections.length) {
    const setActive = (id) => {
      navLinks.forEach((link) => {
        link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      { rootMargin: '-40% 0px -55% 0px' }
    );

    sections.forEach((section) => observer.observe(section));
  }

  // loading bar fills on scroll
  const loadBar = document.getElementById('loading-bar');
  const loadBarInner = document.getElementById('loading-bar-inner');
  if (loadBarInner) {
    const updateLoadBar = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
      loadBarInner.style.width = pct + '%';
    };
    window.addEventListener('scroll', updateLoadBar, { passive: true });
    updateLoadBar();
  }
</script>

<style>
  .hero-window {
    margin-top: 24px;
  }

  .hero-body {
    text-align: center;
    padding: 40px 20px 32px;
    position: relative;
  }

  .hero-sub {
    max-width: 560px;
    margin: 0 auto 20px;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
