---

import PixelIcon from './PixelIcon.astro';

const tabs = [
  { href: '#about', label: 'About' },
  { href: '#what-counts', label: 'What Counts' },
  { href: '#how-it-works', label: 'How It Works' },
  { href: '/Braize/shop/', label: 'Shop' },
  { href: '#connect', label: 'Connect' },
  { href: '#prize', label: 'Prize + FAQ' },
];
---

<div class="window hero-window">
  <div class="title-bar" style="--title-color: var(--hc-red); --title-color-2: var(--hc-orange);">
    <div class="title-bar-text">
      <PixelIcon name="folder" /> Braize.exe
    </div>
    <div class="title-bar-controls">
      <button type="button" aria-label="Minimize">&#95;</button>
      <button type="button" aria-label="Maximize">&#9633;</button>
      <button type="button" class="close-btn" aria-label="Close" id="close-btn">&#10005;</button>
    </div>
  </div>

  <div class="marquee" aria-hidden="true">
    <span>&#9733; Hack Club YSWS &#9733; Build something browser-adjacent &#9733; Keep notes &#9733; Ship a link &#9733; Ask in #braize if unsure &#9733;</span>
  </div>

  <div class="loading-bar" id="loading-bar">
    <div class="loading-bar-inner" id="loading-bar-inner"></div>
  </div>

  <nav class="tab-strip" aria-label="Section navigation" id="section-nav">
    {tabs.map((tab) => <a href={tab.href}>{tab.label}</a>)}
  </nav>

  <div class="address-bar-row">
    <button type="button" class="nav-btn" aria-label="Back" disabled>&#8592;</button>
    <button type="button" class="nav-btn" aria-label="Forward" disabled>&#8594;</button>
    <button type="button" class="nav-btn" aria-label="Refresh" disabled>&#8635;</button>
    <div class="address-bar bevel-in">
      <span class="label">Address:</span>
      <span class="typed" id="typed-text"></span><span class="caret"></span>
    </div>
  </div>

  <div class="window-body hero-body">
    <div class="hero-copy">
      <p class="hero-kicker">a Hack Club YSWS</p>
      <h1 id="hero-heading">make a thing for the web</h1>
      <p class="hero-sub">
        Braize is for browser-adjacent projects: extensions, little utilities,
        from-scratch browsers, cursed experiments, anything someone can poke at.
      </p>
      <ul class="hero-checklist" aria-label="Braize summary">
        <li>build it in public</li>
        <li>keep notes and proof</li>
        <li>submit through the form once it lands</li>
        <li>get reviewed for prizes</li>
      </ul>
      <div class="hero-actions">
        <a class="btn btn-accent hero-primary" href="/Braize/dashboard/">Submission form</a>
        <a class="btn" href="/Braize/shop/">See prizes</a>
        <a class="btn" href="#how-it-works">How it works</a>
      </div>
      <div class="hero-prompt-row" aria-label="Project ideas">
        <span>extension</span>
        <span>tiny browser</span>
        <span>tab tool</span>
        <span>web pet</span>
        <span>request x-ray</span>
      </div>
    </div>
    <aside class="hero-desk" aria-label="Braize notes">
      <div class="mini-window mini-channel">
        <div class="mini-title">#braize</div>
        <strong><span id="braize-channel-count">--</span><span> people poking at the web</span></strong>
        <span>ask ideas, get unstuck, show ugly demos</span>
      </div>
      <div class="sticky-card mini-why">
        <strong>why?</strong>
        <span>browsers hide everything. build around them until the web feels less fake.</span>
      </div>
      <div class="sticky-card mini-prizes">
        <strong>prizes</strong>
        <span>web-ish stuff: browser credits, mice, keyboards, monitors.</span>
      </div>
    </aside>
  </div>

  <div class="status-bar" id="status-bar">Ready.</div>
</div>

<script>
  const phrases = [
    'a browser...',
    'a browser extension...',
    'a browsing buddy...',
    'literally anything with "browse" in it...',
  ];

  const el = document.getElementById('typed-text');
  const WORKER_URL = 'https://braize-worker.braize.workers.dev';
  const channelCount = document.getElementById('braize-channel-count');

  if (el) {
    let phraseIndex = 0;
    let charIndex = 0;
    let deleting = false;

    const tick = () => {
      const phrase = phrases[phraseIndex];

      if (!deleting) {
        charIndex++;
        el.textContent = phrase.slice(0, charIndex);
        if (charIndex === phrase.length) {
          deleting = true;
          setTimeout(tick, 1400);
          return;
        }
      } else {
        charIndex--;
        el.textContent = phrase.slice(0, charIndex);
        if (charIndex === 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % phrases.length;
        }
      }

      setTimeout(tick, deleting ? 40 : 70);
    };

    tick();
  }

  if (channelCount) {
    fetch(`${WORKER_URL}/public/stats`)
      .then((res) => (res.ok ? res.json() : null))
      .then((body) => {
        const count = body?.stats?.braizeChannelMembers;
        if (typeof count === 'number') channelCount.textContent = `${count}`;
      })
      .catch(() => {});
  }

  const closeBtn = document.getElementById('close-btn');
  const statusBar = document.getElementById('status-bar');

  closeBtn?.addEventListener('click', () => {
    document.body.classList.add('shake');
    setTimeout(() => document.body.classList.remove('shake'), 400);

    const heading = document.getElementById('hero-heading');
    if (heading) {
      heading.setAttribute('data-text', heading.textContent || '');
      heading.classList.add('glitch');
      setTimeout(() => {
        heading.classList.remove('glitch');
        heading.removeAttribute('data-text');
      }, 400);
    }

    closeBtn.classList.remove('wobble');
    void closeBtn.offsetWidth;
    closeBtn.classList.add('wobble');

    if (statusBar) statusBar.textContent = 'No closing. Window has feelings.';
    setTimeout(() => {
      if (statusBar) statusBar.textContent = 'Ready.';
    }, 2000);
  });

  const navLinks = document.querySelectorAll('#section-nav a');
  const sections = Array.from(navLinks)
    .map((link) => document.getElementById(link.getAttribute('href').slice(1)))
    .filter(Boolean);

  if (sections.length) {
    const setActive = (id) => {
      navLinks.forEach((link) => {
        link.classList.toggle('active', link.getAttribute('href') === `#${id}`);
      });
    };

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries.filter((e) => e.isIntersecting);
        if (visible.length > 0) {
          setActive(visible[0].target.id);
        }
      },
      { rootMargin: '-40% 0px -55% 0px' }
    );

    sections.forEach((section) => observer.observe(section));
  }

  // loading bar fills on scroll
  const loadBar = document.getElementById('loading-bar');
  const loadBarInner = document.getElementById('loading-bar-inner');
  if (loadBarInner) {
    const updateLoadBar = () => {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const pct = docHeight > 0 ? Math.min(100, (scrollTop / docHeight) * 100) : 0;
      loadBarInner.style.width = pct + '%';
    };
    window.addEventListener('scroll', updateLoadBar, { passive: true });
    updateLoadBar();
  }
</script>

<style>
  .hero-window {
    margin-top: 24px;
    box-shadow:
      inset -1px -1px var(--win-dark-shadow),
      inset 1px 1px var(--win-light-highlight),
      12px 12px 0 rgba(0,0,0,0.24);
  }

  .hero-body {
    min-height: 540px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 320px);
    align-items: center;
    gap: 28px;
    text-align: left;
    padding: 54px 30px 44px;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(255,255,255,0.66) 0 1px, transparent 1px 100%),
      linear-gradient(0deg, rgba(255,255,255,0.66) 0 1px, transparent 1px 100%),
      linear-gradient(135deg, #f7efd0, #d7f0ed 58%, #f4d6dc),
      var(--win-face);
    background-size: 28px 28px, 28px 28px, auto;
  }

  .hero-body::before {
    content: none;
    position: absolute;
    left: 22px;
    top: 18px;
    width: 70px;
    height: 42px;
    border: 3px solid var(--hc-red);
    transform: rotate(-7deg);
    pointer-events: none;
  }

  .hero-body::after {
    content: none;
    position: absolute;
    right: 28px;
    bottom: 24px;
    width: 120px;
    height: 22px;
    pointer-events: none;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: 0 0 0 1px rgba(0,0,0,0.08);
    transform: rotate(-5deg);
  }

  .hero-copy {
    position: relative;
    z-index: 2;
    max-width: 620px;
  }

  .hero-kicker {
    display: inline-block;
    margin: 0 0 10px;
    padding: 5px 12px;
    font-family: var(--font-hand);
    font-size: 1.25rem;
    color: #111;
    background: #fff4a8;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.14);
    transform: rotate(-2deg);
  }

  .hero-body h1 {
    margin-bottom: 0.16em;
    font-family: var(--font-hand);
    font-size: clamp(4.2rem, 13vw, 8.4rem);
    color: #111;
    letter-spacing: -2px;
    line-height: 0.9;
    transform: rotate(-1deg);
    text-shadow: 3px 3px 0 #fff, 6px 6px 0 var(--hc-yellow);
  }

  .hero-sub {
    max-width: 680px;
    margin: 0 0 16px;
    font-size: 1.05rem;
    color: #060606;
    background: rgba(255,255,255,0.72);
    padding: 14px 16px;
    box-shadow:
      inset 1px 1px var(--win-light-highlight),
      inset -1px -1px var(--win-shadow),
      5px 5px 0 rgba(0,0,0,0.14);
  }

  .hero-checklist {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px 14px;
    margin: 0 0 22px;
    padding: 0;
    list-style: none;
  }

  .hero-checklist li {
    position: relative;
    padding-left: 24px;
    font-family: var(--font-hand);
    font-size: 1.28rem;
  }

  .hero-checklist li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.35em;
    width: 14px;
    height: 14px;
    background: #fff;
    border: 2px solid #111;
    box-shadow: 2px 2px 0 var(--hc-green);
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-start;
    flex-wrap: wrap;
  }

  .hero-prompt-row {
    display: flex;
    flex-wrap: wrap;
    gap: 9px;
    margin-top: 26px;
    max-width: 620px;
  }

  .hero-prompt-row span {
    padding: 7px 10px;
    font-family: var(--font-hand);
    font-size: 1.18rem;
    line-height: 1;
    color: #111;
    background: #fff;
    box-shadow: 4px 4px 0 rgba(0,0,0,0.12);
    transform: rotate(-1deg);
  }

  .hero-prompt-row span:nth-child(2n) {
    background: #d8f4ff;
    transform: rotate(1deg);
  }

  .hero-prompt-row span:nth-child(3n) {
    background: #e6ffd8;
  }

  .hero-primary {
    background: var(--hc-yellow);
    transform: scale(1.08) rotate(-1deg);
    box-shadow:
      inset -1px -1px var(--win-dark-shadow),
      inset 1px 1px var(--win-light-highlight),
      inset -2px -2px var(--win-shadow),
      inset 2px 2px var(--win-highlight),
      6px 6px 0 rgba(0,0,0,0.22);
  }

  .hero-desk {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 18px;
    align-self: stretch;
    align-content: center;
  }

  .mini-window,
  .sticky-card {
    position: relative;
    display: grid;
    gap: 8px;
    padding: 16px;
    color: #111;
    box-shadow: 7px 7px 0 rgba(0,0,0,0.16);
  }

  .mini-window {
    padding-top: 38px;
    background:
      repeating-linear-gradient(#fff 0 23px, #d9ecff 23px 24px),
      #fff;
    box-shadow:
      inset -1px -1px var(--win-shadow),
      inset 1px 1px var(--win-light-highlight),
      7px 7px 0 rgba(0,0,0,0.16);
  }

  .mini-title {
    position: absolute;
    inset: 0 0 auto;
    padding: 5px 8px;
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: bold;
    color: #fff;
    background: linear-gradient(90deg, var(--hc-blue), var(--hc-purple));
  }

  .sticky-card {
    font-family: var(--font-hand);
    background: #fff4a8;
  }

  .mini-window strong,
  .sticky-card strong {
    font-size: 1.42rem;
    line-height: 1;
  }

  .mini-channel strong {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 10px;
  }

  #braize-channel-count {
    display: inline-grid;
    place-items: center;
    min-width: 72px;
    padding: 4px 10px;
    font-family: var(--font-display);
    font-size: 3.6rem;
    line-height: 0.82;
    color: var(--hc-green);
    background: #050505;
    box-shadow: inset 0 0 0 2px var(--hc-green), 5px 5px 0 rgba(0,0,0,0.16);
  }

  .sticky-card span,
  .mini-window span {
    font-size: 1rem;
    line-height: 1.3;
  }

  .mini-channel { transform: rotate(1.2deg); }
  .mini-why { background: #ffd7df; transform: rotate(-2.5deg); }
  .mini-prizes { background: #e6ffd8; transform: rotate(2deg); }

  .hero-desk::before {
    content: none;
    position: absolute;
    inset: 38px 18px 30px;
    z-index: -1;
    background: rgba(255,255,255,0.28);
    border: 2px dashed rgba(0,0,0,0.12);
    transform: rotate(1deg);
  }

  @media (max-width: 720px) {
    .hero-body {
      grid-template-columns: 1fr;
      min-height: auto;
      padding: 44px 14px 34px;
    }

    .hero-desk {
      grid-template-columns: 1fr;
    }

    .mini-channel,
    .mini-why,
    .mini-prizes {
      transform: none;
    }

    #braize-channel-count {
      font-size: 3rem;
      min-width: 62px;
    }

    .hero-checklist { grid-template-columns: 1fr; }

    .hero-body h1 {
      font-size: clamp(3.2rem, 18vw, 5.6rem);
      text-shadow:
        3px 3px 0 #fff,
        6px 6px 0 var(--hc-yellow);
    }

    .hero-primary {
      transform: none;
    }
  }
</style>
